<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_quick_capture_bg"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/quick_capture_shell_eyebrow"
        android:textAllCaps="true"
        android:textColor="#FF6B7A93"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/quick_capture_shell_title"
        android:textColor="#FF152033"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/quick_capture_shell_helper"
        android:textColor="#FF60708A"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/quick_capture_count_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/quick_capture_status_chip"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/quick_capture_buffer_count_zero"
            android:textColor="#FF2363FF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/quick_capture_status_chip_muted"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/quick_capture_pool_label"
            android:textColor="#FF475569"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/quick_capture_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/quick_capture_status_panel"
        android:padding="14dp"
        android:text="@string/quick_capture_ready"
        android:textColor="#FF4B5B75"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1"
        android:background="@drawable/quick_capture_surface_panel"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_capture_input_label"
            android:textColor="#FF152033"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/quick_capture_input_helper"
            android:textColor="#FF60708A"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/quick_capture_input"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="top|start"
            android:hint="@string/quick_capture_input_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="8"
            android:padding="0dp"
            android:textColor="#FF0F172A"
            android:textColorHint="#9960708A"
            android:textSize="16sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/quick_capture_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="16dp"
        android:indeterminate="true"
        android:indeterminateTint="#FF2363FF"
        android:progressBackgroundTint="#1A2363FF"
        android:visibility="gone" />

    <Button
        android:id="@+id/quick_capture_submit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/quick_capture_primary_button"
        android:text="@string/quick_capture_buffer_add"
        android:textAllCaps="false"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp" />

    <Button
        android:id="@+id/quick_capture_open_full"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/quick_capture_secondary_button"
        android:text="@string/quick_capture_process"
        android:textAllCaps="false"
        android:textColor="#FF152033"
        android:textSize="18sp" />
</LinearLayout>
